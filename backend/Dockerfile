FROM node:22-alpine

WORKDIR /app

ENV NODE_ENV=production

COPY package*.json ./
RUN npm ci --omit=dev

COPY src ./src

EXPOSE 5000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD ["node", "-e", "const port=process.env.PORT||5000; fetch('http://127.0.0.1:'+port).then((res)=>process.exit(res.ok?0:1)).catch(()=>process.exit(1))"]

CMD ["npm", "start"]
